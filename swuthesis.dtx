% \textsf{tocloft} 在 |\AtBeginDocument| 末尾才把 |\tableofcontents| 换成其定义；
% 若在类文件里过早 |\let\swu@oldtableofcontents\tableofcontents|，
% 抓到的是 \texttt{book} 原版，
% 且本类对 |\tableofcontents| 的改写会在 |\begin{document}| 时被 tocloft 覆盖，
% 故目录页 |\pagenumbering{Roman}| 等永远不生效。
\AtBeginDocument{%
  \ifswu@gradthesis
    \addtolength{\headheight}{8pt}%
  \fi
  \let\swu@oldtableofcontents\tableofcontents
  \renewcommand{\tableofcontents}{%
    \clearpage
    \ifswu@postdoc\else\pagenumbering{Roman}\fi
    \begingroup
    \ifswu@gradthesis
      \setstretch{1.67}%
    \else
      \setstretch{1.5}%
    \fi
    \swu@oldtableofcontents
    \endgroup
  }%
}%
